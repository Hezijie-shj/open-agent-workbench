COMPOSE_PROJECT_NAME=open-agent-workbench
APP_ENV=demo

# Host ports. Change these if the ports are already used on your machine.
FRONTEND_PORT=5173
BACKEND_PORT=8001

# Path inside the backend container. docker-compose.yaml mounts ./config to /app/config.
CONFIG_PATH=/app/config/config.toml

# Backend log level: debug, info, warning, error.
LOG_LEVEL=info
